{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Dot map of Australian universities. Clicking a dot fires the uni_select point-selection, which JS bridges to the enrolments bar chart.",
  "width": "container",
  "height": 360,
  "background": "#FFFDF7",
  "projection": { "type": "mercator" },
  "layer": [
    {
      "data": {
        "url": "js/ne_10m_admin_1_states_provinces_australia.topojson",
        "format": {
          "type": "topojson",
          "feature": "ne_10m_admin_1_states_provinces"
        }
      },
      "mark": {
        "type": "geoshape",
        "fill": "#3e3c39",
        "stroke": "#FFFDF7",
        "strokeWidth": 0.8
      }
    },
    {
      "data": { "url": "data/university_locations.csv" },
      "params": [
        {
          "name": "uni_select",
          "select": { "type": "point", "fields": ["institution"], "toggle": false },
          "value": []
        }
      ],
      "mark": {
        "type": "circle",
        "size": 90,
        "stroke": "#0a0a0a",
        "strokeWidth": 0.6,
        "cursor": "pointer"
      },
      "encoding": {
        "longitude": { "field": "longitude", "type": "quantitative" },
        "latitude":  { "field": "latitude",  "type": "quantitative" },
        "color": {
          "condition": { "param": "uni_select", "empty": true, "value": "rgba(255, 68, 0, 0.723)" },
          "value": "#2cdada"
        },
        "size": {
          "condition": { "param": "uni_select", "empty": true, "value": 220 },
          "value": 90
        },
        "tooltip": [
          { "field": "institution", "type": "nominal", "title": "University" },
          { "field": "state",       "type": "nominal", "title": "State" }
        ]
      }
    }
  ],
  "config": {
    "view": { "stroke": null }
  }
}
