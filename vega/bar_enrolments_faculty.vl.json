{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Radial (concentric race-track) bar chart of university enrolments by field of education (faculty). Each faculty is its own ring; the swept angle encodes enrolments and a colour legend identifies the ring. Reactive to year_selection (year as string; 'All' = sum across 2020-2024) and selected_university (institution name; 'All' = sum across all universities). Both signals are set externally from HTML.",
  "width": "container",
  "height": 380,
  "background": "transparent",
  "data": { "url": "data/university_enrolments_long.csv" },
  "params": [
    { "name": "year_selection",      "value": "All" },
    { "name": "selected_university", "value": "All" }
  ],
  "transform": [
    {
      "filter": "year_selection == 'All' || datum.year == toNumber(year_selection)"
    },
    {
      "filter": "selected_university == 'All' || datum.institution == selected_university"
    },
    {
      "aggregate": [{"op": "sum", "field": "enrolments", "as": "total"}],
      "groupby": ["faculty"]
    },
    {
      "window": [{"op": "rank", "as": "ring"}],
      "sort": [{"field": "total", "order": "ascending"}]
    },
    { "calculate": "26 + (datum.ring - 1) * 9.5", "as": "r_inner" },
    { "calculate": "datum.r_inner + 10",            "as": "r_outer" }
  ],
  "mark": { "type": "arc", "cornerRadius": 2, "stroke": "#ffffff", "strokeWidth": 1},
  "encoding": {
    "theta": {
      "field": "total",
      "type": "quantitative",
      "stack": null,
      "scale": {
        "domain": { "expr": "selected_university != 'All' ? [0, 80000] : (year_selection == 'All' ? [0, 1800000] : [0, 400000])" },
        "range": [0, 6.05]
      }
    },
    "radius":  { "field": "r_outer", "type": "quantitative", "scale": null },
    "radius2": { "field": "r_inner", "type": "quantitative", "scale": null },
    "color": {
      "field": "faculty",
      "type": "nominal",
      "scale": {
        "domain": [
          "Management and Commerce",
          "Society and Culture",
          "Health",
          "Information Technology",
          "Education",
          "Natural and Physical Sciences",
          "Engineering and Related Technologies",
          "Creative Arts",
          "Architecture and Building",
          "Agriculture, Environmental and Related Studies",
          "Non-Award Courses",
          "Mixed Field Programmes",
          "Food, Hospitality and Personal Services"
        ],
"range": [
  "#4a6fa5",
  "#5a7fb5",
  "#6a8fc5",
  "#7a9fd5",
  "#8aafd5",
  "#7a8fa5",
  "#6a7f95",
  "#e8a0bf",
  "#5a6f85",
  "#4a5f75",
  "#8a9aaa",
  "#9aaaba",
  "#aabaca"
]
      },
      "legend": {
        "title": "Field of study",
        "orient": "right",
        "direction": "vertical",
        "symbolType": "circle",
        "labelLimit": 180,
        "labelFontSize": 10,
        "titleFontSize": 11,
        "rowPadding": 3
      }
    },
    "tooltip": [
      { "field": "faculty", "type": "nominal",      "title": "Field of study" },
      { "field": "total",   "type": "quantitative", "title": "Enrolments", "format": "," }
    ]
  },
  "config": {
    "view":  { "stroke": null },
    "legend": { "labelColor": "#3e3c39", "titleColor": "#3e3c39" },
    "font":  "Host Grotesk, Helvetica, sans-serif"
  }
}
