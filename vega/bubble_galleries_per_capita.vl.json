{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Small multiples of Australian state outlines with proportional bubbles encoding art galleries per 100,000 residents. Panels sorted left to right by rate descending; each state map auto-fits its column and a proportional bubble is pinned to the panel centre, so all maps and bubbles share one horizontal axis directly above their subheading. Gallery counts aggregated live from artguide_galleries.csv; population from ABS Sep-2025 release. A pow(2) size scale makes bubble radius proportional to rate for dramatic size contrast, with a vertical reference size legend on the right.",
  "background": "transparent",
  "spacing": 8,
  "center": true,
  "config": {
    "view": {
      "stroke": null
    },
    "font": "Host Grotesk, Helvetica, sans-serif"
  },
  "resolve": {
    "scale": {
      "size": "independent"
    }
  },
  "hconcat": [
    {
      "width": 120,
      "height": 140,
      "background": "transparent",
      "title": {
        "text": "ACT",
        "subtitle": "5.1 per 100k",
        "orient": "bottom",
        "anchor": "middle",
        "fontSize": 11,
        "color": "#3e3c39",
        "fontWeight": 600,
        "subtitleColor": "#857d82",
        "subtitleFontSize": 9,
        "subtitleFontStyle": "italic",
        "subtitlePadding": 2
      },
      "projection": {
        "type": "mercator"
      },
      "layer": [
        {
          "data": {
            "url": "../js/ne_10m_admin_1_states_provinces_australia.topojson",
            "format": {
              "type": "topojson",
              "feature": "ne_10m_admin_1_states_provinces"
            }
          },
          "transform": [
            {
              "filter": "datum.properties.name == 'Australian Capital Territory'"
            }
          ],
          "mark": {
            "type": "geoshape",
            "fill": "#3e3c39",
            "fillOpacity": 0.55,
            "stroke": "#5a5753",
            "strokeWidth": 0.8
          }
        },
        {
          "data": {
            "url": "../data/artguide_galleries.csv"
          },
          "transform": [
            {
              "filter": "datum.state == 'ACT'"
            },
            {
              "aggregate": [
                {
                  "op": "count",
                  "as": "gallery_count"
                }
              ],
              "groupby": [
                "state"
              ]
            },
            {
              "calculate": "'Australian Capital Territory'",
              "as": "state_name"
            },
            {
              "calculate": "486.2",
              "as": "pop_k"
            },
            {
              "calculate": "datum.pop_k * 1000",
              "as": "population_people"
            },
            {
              "calculate": "datum.gallery_count / datum.pop_k * 100",
              "as": "per100k"
            }
          ],
          "mark": {
            "type": "circle",
            "fill": "#b8a8e8",
            "fillOpacity": 0.82,
            "stroke": "#7a6bb8",
            "strokeWidth": 1
          },
          "encoding": {
            "x": {
              "value": 60
            },
            "y": {
              "value": 64
            },
            "size": {
              "field": "per100k",
              "type": "quantitative",
              "scale": {
                "type": "pow",
                "exponent": 2,
                "domain": [
                  0,
                  5.5
                ],
                "range": [
                  0,
                  3400
                ]
              },
              "legend": null
            },
            "tooltip": [
              {
                "field": "state_name",
                "type": "nominal",
                "title": "State"
              },
              {
                "field": "gallery_count",
                "type": "quantitative",
                "title": "Galleries",
                "format": ","
              },
              {
                "field": "population_people",
                "type": "quantitative",
                "title": "Population",
                "format": ",.0f"
              },
              {
                "field": "per100k",
                "type": "quantitative",
                "title": "Galleries per 100,000",
                "format": ".1f"
              }
            ]
          }
        }
      ]
    },
