{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Two side-by-side bar charts of the creative workforce. Left: number employed in each role (simple ranking). Right: each role's salary as a deviation from the average — bars above the zero line earn more than average, bars below earn less. The average salary across the 14 roles with published figures is approximately AUD 96,230 (hardcoded; recompute if data changes). Fashion Designer has no published salary at any ANZSCO level and is excluded from the right chart.",
  "background": "transparent",
  "data": {
    "url": "data/occupations_arts.csv",
    "format": {
      "type": "csv",
      "parse": {
        "employed": "number",
        "annual_salary_aud": "number"
      }
    }
  },
  "spacing": 50,
  "hconcat": [

    {
      "title": {
        "text": "How many people work in each creative role",
        "anchor": "start"
      },
      "width": 300,
      "height": 400,
      "mark": {
        "type": "bar",
        "color": "#857d82",
        "size": 14
      },
      "encoding": {
        "y": {
          "field": "occupation",
          "type": "nominal",
          "sort": { "field": "employed", "op": "max", "order": "descending" },
          "title": null,
          "axis": { "labelLimit": 220 }
        },
        "x": {
          "field": "employed",
          "type": "quantitative",
          "title": "People currently employed",
          "axis": {
            "labelExpr": "replace(format(datum.value, '~s'), 'k', 'K')"
          }
        },
        "tooltip": [
          { "field": "occupation", "type": "nominal" },
          { "field": "employed",   "type": "quantitative", "format": "," }
        ]
      }
    },

    {
      "title": {
        "text": "Which roles pay above or below the average",
        "subtitle": "Average across roles with published salaries: AUD 96,230. Fashion Designer excluded (no published salary)."
      },
      "width": 300,
      "height": 400,
      "transform": [
        { "filter": "isValid(datum.annual_salary_aud) && datum.annual_salary_aud > 0" },
        { "calculate": "datum.annual_salary_aud - 96230", "as": "salary_diff" }
      ],
      "layer": [
        {
          "mark": { "type": "bar", "size": 14 },
          "encoding": {
            "y": {
              "field": "occupation",
              "type": "nominal",
              "sort": { "field": "salary_diff", "op": "max", "order": "descending" },
              "title": null,
              "axis": { "labelLimit": 220 }
            },
            "x": {
              "field": "salary_diff",
              "type": "quantitative",
              "title": "Difference from the average",
              "scale": { "domain": [-20000, 20000] },
              "axis": {
                "labelExpr": "(datum.value < 0 ? '-$' : datum.value > 0 ? '+$' : '$') + replace(format(abs(datum.value), '~s'), 'k', 'K')"
              }
            },
            "color": {
              "condition": { "test": "datum.salary_diff > 0", "value": "#a86b52" },
              "value": "#6b7a8f"
            },
            "tooltip": [
              { "field": "occupation",        "type": "nominal" },
              { "field": "annual_salary_aud", "type": "quantitative", "format": "$,.0f", "title": "Avg. annual salary (AUD)" },
              { "field": "salary_diff",       "type": "quantitative", "format": "$,.0f", "title": "Difference from average" }
            ]
          }
        },
        {
          "mark": { "type": "rule", "color": "#5a5753", "strokeWidth": 1 },
          "encoding": {
            "x": { "datum": 0 }
          }
        }
      ]
    }
  ],

  "config": {
    "view": { "stroke": null },
    "axis": {
      "domainColor": "#5a5753",
      "tickColor":   "#5a5753",
      "labelColor":  "#3e3c39",
      "titleColor":  "#3e3c39",
      "gridColor":   "rgba(0,0,0,0.06)",
      "labelFontSize": 11,
      "titleFontSize": 11,
      "grid": true
    },
    "title": {
      "fontSize":   14,
      "fontWeight": 600,
      "color":      "#3e3c39",
      "subtitleFontSize":  10,
      "subtitleColor":     "#857d82",
      "subtitleFontStyle": "italic"
    },
    "font": "Host Grotesk, Helvetica, sans-serif"
  }
}
